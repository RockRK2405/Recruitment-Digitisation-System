# ─── Core ──────────────────────────────────────────────────────────────────
PROJECT_NAME="WorkforceAI Recruitment Platform"
ENV=development
DEBUG=true

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pwd_2026
POSTGRES_DB=workforce_recruitment
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres_secure_pwd_2026@localhost:5432/workforce_recruitment

# ─── API Gateway (Node.js) ───────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars
CORS_ORIGIN=http://localhost:3000

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Set to 'ollama' for local inference, 'gemini' for Google cloud
LLM_PROVIDER=ollama

# Ollama (local) — pull model with: ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_VISION_MODEL=llava:13b
OLLAMA_VISION_URL=http://localhost:11434/api/generate

# Google Gemini (cloud fallback) — get key at: https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Python AI Service ──────────────────────────────────────────────────────
API_PORT=8000
CHROMA_DB_PATH=./data/chromadb
UPLOAD_DIR=./data/uploads
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base

# ─── OCR ────────────────────────────────────────────────────────────────────
EASYOCR_LANGUAGES=["en", "hi"]
VISION_ENABLED=true
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6
FIELD_CONFIDENCE_THRESHOLD=0.5

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

