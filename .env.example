# Project Settings
PROJECT_NAME="Industrial Workforce Recruitment Platform"
ENV=development
DEBUG=true

# FastAPI & Streamlit Ports
API_PORT=8000
UI_PORT=8501

# PostgreSQL Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pwd_2026
POSTGRES_DB=workforce_recruitment
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres_secure_pwd_2026@localhost:5432/workforce_recruitment

# Vector Database (ChromaDB)
CHROMA_DB_PATH=./data/chromadb
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base

# AI Intelligence & Extraction (Gemini API)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# Logging
LOG_LEVEL=INFO
